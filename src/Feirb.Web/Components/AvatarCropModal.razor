@inject IJSRuntime JsRuntime
@inject IStringLocalizer<SharedResources> L
@implements IAsyncDisposable

@if (_visible)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-label="@L["AvatarCropTitle"]">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["AvatarCropTitle"]</h5>
                    <button type="button" class="btn-close" @onclick="CancelAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="avatar-crop-container">
                        <img @ref="_imageRef" src="@_imageSrc" alt="" class="avatar-crop-image" />
                    </div>
                </div>
                <div class="modal-footer">
                    <Button Variant="ButtonVariant.Secondary" OnClick="CancelAsync">@L["AvatarCancel"]</Button>
                    <Button Variant="ButtonVariant.Primary" Icon="check-lg" OnClick="SaveAsync" Disabled="_isSaving">
                        @L["AvatarSave"]
                    </Button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public EventCallback<byte[]> OnCropped { get; set; }

    private bool _visible;
    private bool _isSaving;
    private string? _imageSrc;
    private ElementReference _imageRef;

    public async Task ShowAsync(string dataUrl)
    {
        _imageSrc = dataUrl;
        _visible = true;
        StateHasChanged();

        // Wait for the DOM to render, then initialize Cropper.js
        await Task.Delay(100);
        await JsRuntime.InvokeVoidAsync("cropperInterop.init", _imageRef);
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            var base64 = await JsRuntime.InvokeAsync<string?>("cropperInterop.getCroppedImageBase64", 256, 256);
            if (base64 is not null)
            {
                var bytes = Convert.FromBase64String(base64);
                await CloseAsync();
                await OnCropped.InvokeAsync(bytes);
                return;
            }
        }
        finally
        {
            _isSaving = false;
        }

        await CloseAsync();
    }

    private async Task CancelAsync()
    {
        await CloseAsync();
    }

    private async Task CloseAsync()
    {
        await JsRuntime.InvokeVoidAsync("cropperInterop.destroy");
        _visible = false;
        _imageSrc = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("cropperInterop.destroy");
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, safe to ignore
        }
    }
}

@namespace Feirb.Web.Components.UI
@implements IAsyncDisposable
@inject IJSRuntime Js

@* Data-driven sidebar menu with optional section headers and a bottom-pinned slot. *@
<nav class="feirb-sidebar-menu @Class" aria-label="@AriaLabel" @ref="_navRef">
    <div class="sidebar-menu-main">
        @{ var sectionIndex = 0; }
        @foreach (var menuSection in Sections)
        {
            var sectionId = !string.IsNullOrEmpty(menuSection.Label)
                ? $"sidebar-section-{sectionIndex}"
                : (string?)null;

            <div class="sidebar-menu-section">
                @if (sectionId is not null)
                {
                    <p id="@sectionId" class="sidebar-menu-section-label">@menuSection.Label</p>
                }
                <ul class="sidebar-menu-list" role="menu"
                    aria-labelledby="@sectionId" aria-label="@(sectionId is null ? AriaLabel : null)">
                    @foreach (var item in menuSection.Items)
                    {
                        if (item.Visible is not null && !item.Visible())
                        {
                            continue;
                        }

                        <li role="none">
                            @if (item.OnClick is not null)
                            {
                                <button class="sidebar-menu-entry" role="menuitem" tabindex="-1"
                                        @onclick="item.OnClick">
                                    <Icon Name="@item.Icon" />
                                    <span>@item.Label</span>
                                </button>
                            }
                            else
                            {
                                var match = item.Match
                                    ?? (string.IsNullOrEmpty(item.Href) || item.Href == "/"
                                        ? NavLinkMatch.All
                                        : NavLinkMatch.Prefix);

                                <NavLink class="sidebar-menu-entry" href="@item.Href" Match="@match"
                                         role="menuitem" tabindex="-1">
                                    <Icon Name="@item.Icon" />
                                    <span>@item.Label</span>
                                </NavLink>
                            }
                        </li>
                    }
                </ul>
            </div>

            sectionIndex++;
        }
    </div>

    @if (BottomItems is { Count: > 0 })
    {
        <div class="sidebar-menu-bottom">
            <ul class="sidebar-menu-list" role="menu" aria-label="@AriaLabel actions">
                @foreach (var item in BottomItems)
                {
                    if (item.Visible is not null && !item.Visible())
                    {
                        continue;
                    }

                    <li role="none">
                        @if (item.OnClick is not null)
                        {
                            <button class="sidebar-menu-entry" role="menuitem" tabindex="-1"
                                    @onclick="item.OnClick">
                                <Icon Name="@item.Icon" />
                                <span>@item.Label</span>
                            </button>
                        }
                        else
                        {
                            var match = string.IsNullOrEmpty(item.Href) || item.Href == "/"
                                ? NavLinkMatch.All
                                : NavLinkMatch.Prefix;

                            <NavLink class="sidebar-menu-entry" href="@item.Href" Match="@match"
                                     role="menuitem" tabindex="-1">
                                <Icon Name="@item.Icon" />
                                <span>@item.Label</span>
                            </NavLink>
                        }
                    </li>
                }
            </ul>
        </div>
    }
</nav>

@code {
    /// <summary>Menu sections for the main scrollable area.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<SidebarMenuSection> Sections { get; set; } = [];

    /// <summary>Items pinned to the bottom of the sidebar.</summary>
    [Parameter]
    public IReadOnlyList<SidebarMenuItem>? BottomItems { get; set; }

    /// <summary>Accessible label for the nav element.</summary>
    [Parameter]
    public string AriaLabel { get; set; } = "Sidebar navigation";

    /// <summary>Additional CSS classes.</summary>
    [Parameter]
    public string? Class { get; set; }

    private ElementReference _navRef;
    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await Js.InvokeAsync<IJSObjectReference>(
                "import", "./_content/Feirb.Web/Components/UI/SidebarMenu.razor.js");
            await _jsModule.InvokeVoidAsync("initKeyboardNav", _navRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }
}

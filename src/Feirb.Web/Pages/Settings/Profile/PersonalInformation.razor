@page "/settings/personal-information"
@attribute [Authorize]
@using Feirb.Shared.Avatars
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject ToolbarStateService ToolbarState
@inject NotificationService Notifications
@inject UnsavedChangesService UnsavedChanges
@inject ILogger<PersonalInformation> Logger
@implements IDisposable

<PageTitle>@L["PageTitlePersonalInformation"]</PageTitle>

<InfoHeader Title="@L["PageTitlePersonalInformation"]" Icon="person" Subtitle="@L["PageSubtitlePersonalInfo"]">
    <HelpContent>@L["PageHelpPersonalInfo"]</HelpContent>
</InfoHeader>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible py-2" role="alert">
        @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible py-2" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingProfile"]</span>
        </div>
    </div>
}
else if (_model is not null)
{
    <TrackedEditForm Model="_model" OnSave="HandleSaveAsync">
        <DataAnnotationsValidator />

        <div class="d-flex flex-column align-items-center mb-4 gap-2">
            @if (_avatarUrl is not null)
            {
                <img src="@_avatarUrl" alt="@L["AvatarAlt"]" class="avatar-display" />
            }
            else
            {
                <div class="avatar-fallback">
                    <Icon Name="person-circle" Size="IconSize.Large" Class="avatar-fallback-icon" />
                </div>
            }
            <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" Icon="camera"
                    OnClick="TriggerFilePickerAsync">
                @L["AvatarUploadPhoto"]
            </Button>
            <InputFile @ref="_fileInput" OnChange="OnFileSelectedAsync" accept="image/png,image/jpeg,image/webp"
                       class="d-none" />
        </div>

        <ContentSection Icon="person" Title="@L["SectionPersonalInfoTitle"]" Subtitle="@L["SectionPersonalInfoSubtitle"]">
            <div class="mb-3">
                <label for="username" class="form-label">@L["LabelUsername"]</label>
                <InputText id="username" class="form-control" @bind-Value="_model.Username" />
                <ValidationMessage For="() => _model.Username" />
            </div>
            <div class="mb-0">
                <label for="email" class="form-label">@L["LabelEmail"]</label>
                <InputText id="email" class="form-control" type="email" @bind-Value="_model.Email" />
                <ValidationMessage For="() => _model.Email" />
            </div>
        </ContentSection>
    </TrackedEditForm>
}

<AvatarCropModal @ref="_cropModal" OnCropped="OnCroppedAsync" />

@code {
    private ProfileFormModel? _model;
    private bool _isLoading = true;
    private bool _isSaving;
    private ToolbarAction[] _toolbarActions = [];
    private string? _successMessage;
    private string? _errorMessage;
    private string? _avatarUrl;
    private string? _emailHash;
    private InputFile? _fileInput;
    private AvatarCropModal? _cropModal;

    protected override async Task OnInitializedAsync()
    {
        _toolbarActions =
        [
            new ToolbarAction(L["ButtonCancel"], ButtonVariant.Warning, () => { Navigation.NavigateTo("/settings"); return Task.CompletedTask; }, "x-lg"),
            new ToolbarAction(L["ButtonSave"], ButtonVariant.Primary, async () => { await UnsavedChanges.SaveAllAsync(); }, "check-lg")
        ];
        ToolbarState.AddActions(_toolbarActions);

        try
        {
            var profile = await Http.GetFromJsonAsync<ProfileResponse>("/api/settings/profile");
            if (profile is not null)
            {
                _model = new ProfileFormModel
                {
                    Username = profile.Username,
                    Email = profile.Email,
                };
                _emailHash = AvatarHashHelper.ComputeEmailHash(profile.Email);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load profile");
            Notifications.Add(L["ErrorProfileFailed"], NotificationSeverity.Error);
        }
        finally
        {
            _isLoading = false;
        }

        // Load avatar separately so a missing avatar doesn't block the profile form
        try
        {
            await LoadAvatarAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load avatar");
        }
    }

    public void Dispose() => ToolbarState.RemoveActions(_toolbarActions);

    private async Task LoadAvatarAsync()
    {
        if (_emailHash is null) return;

        var response = await Http.GetAsync($"/api/avatars/{_emailHash}");
        if (response.IsSuccessStatusCode)
        {
            _avatarUrl = $"/api/avatars/{_emailHash}?v={DateTime.UtcNow.Ticks}";
        }
        else
        {
            _avatarUrl = null;
        }
    }

    private async Task TriggerFilePickerAsync()
    {
        if (_fileInput?.Element is not null)
        {
            await JsRuntime.InvokeVoidAsync("clickElement", _fileInput.Element);
        }
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 10 * 1024 * 1024)
        {
            Notifications.Add(L["AvatarInvalidFormat"], NotificationSeverity.Error);
            return;
        }

        var buffer = new byte[file.Size];
        await using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        await stream.ReadExactlyAsync(buffer);

        var base64 = Convert.ToBase64String(buffer);
        var dataUrl = $"data:{file.ContentType};base64,{base64}";

        if (_cropModal is not null)
        {
            await _cropModal.ShowAsync(dataUrl);
        }
    }

    private async Task OnCroppedAsync(byte[] imageBytes)
    {
        if (_emailHash is null) return;

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new ByteArrayContent(imageBytes);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("image/png");
            content.Add(fileContent, "file", "avatar.png");

            var response = await Http.PutAsync($"/api/avatars/{_emailHash}", content);

            if (response.IsSuccessStatusCode)
            {
                await LoadAvatarAsync();
                Notifications.Add(L["AvatarUploadSuccess"], NotificationSeverity.Success);
            }
            else
            {
                Notifications.Add(L["AvatarUploadError"], NotificationSeverity.Error);
            }
        }
        catch
        {
            Notifications.Add(L["AvatarUploadError"], NotificationSeverity.Error);
        }

        StateHasChanged();
    }

    private async Task<bool> HandleSaveAsync()
    {
        if (_isSaving || _model is null) return false;
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var request = new UpdateProfileRequest(_model.Username, _model.Email);
            var response = await Http.PutAsJsonAsync("/api/settings/profile", request);

            if (response.IsSuccessStatusCode)
            {
                _successMessage = L["SuccessProfileUpdated"];
                Notifications.Add(L["SuccessProfileUpdated"], NotificationSeverity.Success);

                // Update avatar hash if email changed
                if (_model.Email is not null)
                {
                    var newHash = AvatarHashHelper.ComputeEmailHash(_model.Email);
                    if (newHash != _emailHash)
                    {
                        _emailHash = newHash;
                        await LoadAvatarAsync();
                    }
                }

                return true;
            }

            var error = await response.Content.ReadFromJsonAsync<MessageResponse>();
            _errorMessage = error?.Message ?? L["ErrorProfileFailed"];
        }
        catch
        {
            _errorMessage = L["ErrorProfileFailed"];
        }
        finally
        {
            _isSaving = false;
        }

        return false;
    }

    private sealed class ProfileFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 2)]
        public string? Username { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? Email { get; set; }
    }

}

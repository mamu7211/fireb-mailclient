@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<Heading Level="HeadingLevel.Large" Icon="info-square">InfoHeader</Heading>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Page header with title, optional subtitle, and a toggleable help section. Use this as the top-level header on every page to provide consistent structure and contextual guidance.</p>
    <table class="table table-sm">
        <thead><tr><th>Parameter</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
            <tr><td><code>Title</code></td><td><code>string</code></td><td>required</td><td>Header title text</td></tr>
            <tr><td><code>Level</code></td><td><code>HeadingLevel</code></td><td><code>Large</code></td><td>Heading size: <code>Large</code> (h1), <code>Medium</code> (h2), <code>Small</code> (h3)</td></tr>
            <tr><td><code>Icon</code></td><td><code>string?</code></td><td><code>null</code></td><td>Icon name without <code>bi-</code> prefix</td></tr>
            <tr><td><code>Subtitle</code></td><td><code>string?</code></td><td><code>null</code></td><td>Subtitle text below the title</td></tr>
            <tr><td><code>HelpContent</code></td><td><code>RenderFragment?</code></td><td><code>null</code></td><td>Collapsible help content (shows toggle button when set)</td></tr>
            <tr><td><code>Class</code></td><td><code>string?</code></td><td><code>null</code></td><td>Extra CSS classes</td></tr>
        </tbody>
    </table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <label class="form-label mb-0">Level:</label>
        <select class="form-select form-select-sm w-auto" @bind="_level">
            <option value="@HeadingLevel.Large">Large (h1)</option>
            <option value="@HeadingLevel.Medium">Medium (h2)</option>
            <option value="@HeadingLevel.Small">Small (h3)</option>
        </select>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="ihIcon" @bind="_showIcon" />
            <label class="form-check-label" for="ihIcon">Icon</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="ihSubtitle" @bind="_showSubtitle" />
            <label class="form-check-label" for="ihSubtitle">Subtitle</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="ihHelp" @bind="_showHelp" />
            <label class="form-check-label" for="ihHelp">Help</label>
        </div>
    </div>
    <div class="showcase-preview-area">
        @if (_showHelp)
        {
            <InfoHeader
                Title="Settings"
                Level="@_level"
                Icon="@(_showIcon ? "gear" : null)"
                Subtitle="@(_showSubtitle ? "Manage your account, mailboxes, and preferences" : null)">
                <HelpContent>
                    Here you can configure your personal profile, connect mailboxes via IMAP and SMTP,
                    manage labels for organizing your mail, and set your preferred language.
                    Changes are saved automatically when you navigate away.
                </HelpContent>
            </InfoHeader>
        }
        else
        {
            <InfoHeader
                Title="Settings"
                Level="@_level"
                Icon="@(_showIcon ? "gear" : null)"
                Subtitle="@(_showSubtitle ? "Manage your account, mailboxes, and preferences" : null)" />
        }
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private HeadingLevel _level = HeadingLevel.Large;
    private bool _showIcon = true;
    private bool _showSubtitle = true;
    private bool _showHelp = true;
    private ElementReference _codeElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var levelAttr = _level != HeadingLevel.Large ? $"\n    Level=\"HeadingLevel.{_level}\"" : "";
            var iconAttr = _showIcon ? "\n    Icon=\"gear\"" : "";
            var subtitleAttr = _showSubtitle ? "\n    Subtitle=\"Manage your account, mailboxes, and preferences\"" : "";
            var helpBlock = _showHelp
                ? """

                <HelpContent>
                    Here you can configure your personal profile,
                    connect mailboxes, manage labels, and set
                    your preferred language.
                </HelpContent>
            """
                : "";
            var closing = _showHelp ? $">{helpBlock}\n</InfoHeader>" : " />";
            return $"""
                <InfoHeader
                    Title="Settings"{levelAttr}{iconAttr}{subtitleAttr}{closing}
                """;
        }
    }
}

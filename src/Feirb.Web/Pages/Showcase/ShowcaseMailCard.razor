@using Feirb.Web.Components
@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="MailCard" Icon="envelope" Subtitle="Card component for displaying mail items across different layout contexts" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Card component for displaying mail items. Supports four layout modes: Large, Medium, Small, and Row. Whole card is a clickable navigation target.</p>
    <table class="table table-sm">
        <thead><tr><th>Parameter</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
            <tr><td><code>Mode</code></td><td><code>MailCardMode</code></td><td>required</td><td>Large, Medium, Small, Row</td></tr>
            <tr><td><code>SenderName</code></td><td><code>string</code></td><td>required</td><td>Sender display name</td></tr>
            <tr><td><code>SenderEmail</code></td><td><code>string</code></td><td>required</td><td>Sender email address</td></tr>
            <tr><td><code>Subject</code></td><td><code>string</code></td><td>required</td><td>Mail subject line (truncated)</td></tr>
            <tr><td><code>Summary</code></td><td><code>string?</code></td><td><code>null</code></td><td>Summary text (Large: 3 lines, Medium: 2 lines)</td></tr>
            <tr><td><code>Labels</code></td><td><code>IReadOnlyList&lt;MailCardLabel&gt;</code></td><td><code>[]</code></td><td>Labels to display (overflow with +N)</td></tr>
            <tr><td><code>ReceivedAt</code></td><td><code>DateTime</code></td><td>required</td><td>Received date/time</td></tr>
            <tr><td><code>IsRead</code></td><td><code>bool</code></td><td><code>false</code></td><td>Read/unread state</td></tr>
            <tr><td><code>Href</code></td><td><code>string</code></td><td>required</td><td>Navigation target URL</td></tr>
            <tr><td><code>Class</code></td><td><code>string?</code></td><td><code>null</code></td><td>Extra CSS classes</td></tr>
        </tbody>
    </table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <label class="form-label">Mode</label>
            <select class="form-select form-select-sm" @bind="_mode">
                <option value="@MailCardMode.Large">Large</option>
                <option value="@MailCardMode.Medium">Medium</option>
                <option value="@MailCardMode.Small">Small</option>
                <option value="@MailCardMode.Row">Row</option>
            </select>
        </div>
        <div class="col-md-6 col-lg-3">
            <label class="form-label">Sender Name</label>
            <input type="text" class="form-control form-control-sm" @bind="_senderName" @bind:event="oninput" />
        </div>
        <div class="col-md-6 col-lg-3">
            <label class="form-label">Sender Email</label>
            <input type="text" class="form-control form-control-sm" @bind="_senderEmail" @bind:event="oninput" />
        </div>
        <div class="col-md-6 col-lg-3">
            <label class="form-label">Received At</label>
            <input type="datetime-local" class="form-control form-control-sm" value="@_receivedAt.ToString("yyyy-MM-ddTHH:mm")"
                   @onchange="e => _receivedAt = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _receivedAt" />
        </div>
        <div class="col-12">
            <label class="form-label">Subject</label>
            <input type="text" class="form-control form-control-sm" @bind="_subject" @bind:event="oninput" />
        </div>
        <div class="col-12">
            <label class="form-label">Summary</label>
            <textarea class="form-control form-control-sm" rows="2" @bind="_summary" @bind:event="oninput"></textarea>
        </div>
        <div class="col-md-6 col-lg-3">
            <label class="form-label">Href</label>
            <input type="text" class="form-control form-control-sm" @bind="_href" @bind:event="oninput" />
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="mailCardIsRead" @bind="_isRead" />
                <label class="form-check-label" for="mailCardIsRead">Is Read</label>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Labels</label>
        <div class="d-flex flex-column gap-2 mb-2">
            @for (var i = 0; i < _labels.Count; i++)
            {
                var index = i;
                <div class="d-flex align-items-center gap-2">
                    <input type="text" class="form-control form-control-sm" style="max-width: 10rem;" placeholder="Name"
                           value="@_labels[index].Name"
                           @onchange="@(e => UpdateLabel(index, e.Value?.ToString() ?? "", _labels[index].Color))" />
                    <input type="color" class="form-control form-control-color form-control-sm"
                           value="@(_labels[index].Color ?? "#000000")"
                           @onchange="@(e => UpdateLabel(index, _labels[index].Name, e.Value?.ToString()))" />
                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLabel(index)">
                        <Icon Name="x" Size="IconSize.Small" />
                    </button>
                </div>
            }
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddLabel">
            <Icon Name="plus" Size="IconSize.Small" /> Add label
        </button>
    </div>

    <div class="showcase-preview-area">
        <div style="max-width: 36rem;">
            <MailCard Mode="_mode"
                      SenderName="@_senderName"
                      SenderEmail="@_senderEmail"
                      Subject="@_subject"
                      Summary="@_summary"
                      Labels="@_labels"
                      ReceivedAt="_receivedAt"
                      IsRead="_isRead"
                      Href="@_href" />
        </div>
    </div>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">All Modes</Heading>
    <p class="text-muted mb-3">Comparison of all four layout modes with the same data.</p>
    <div class="d-flex flex-column gap-3">
        @foreach (var mode in Enum.GetValues<MailCardMode>())
        {
            <div>
                <span class="badge bg-secondary mb-2">@mode</span>
                <MailCard Mode="mode"
                          SenderName="@_senderName"
                          SenderEmail="@_senderEmail"
                          Subject="@_subject"
                          Summary="@_summary"
                          Labels="@_labels"
                          ReceivedAt="_receivedAt"
                          IsRead="_isRead"
                          Href="@_href" />
            </div>
        }
    </div>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Label Overflow</Heading>
    <p class="text-muted mb-3">When labels exceed the per-mode cap, a "+N" indicator is shown.</p>
    <div class="d-flex flex-column gap-3">
        <div>
            <span class="badge bg-secondary mb-2">Small (max 1 label)</span>
            <div style="max-width: 24rem;">
                <MailCard Mode="MailCardMode.Small"
                          SenderName="Jane Doe"
                          SenderEmail="jane@example.com"
                          Subject="Project update with many labels"
                          Labels="@_overflowLabels"
                          ReceivedAt="DateTime.Now.AddHours(-2)"
                          IsRead="false"
                          Href="#" />
            </div>
        </div>
        <div>
            <span class="badge bg-secondary mb-2">Medium (max 3 labels)</span>
            <div style="max-width: 30rem;">
                <MailCard Mode="MailCardMode.Medium"
                          SenderName="Jane Doe"
                          SenderEmail="jane@example.com"
                          Subject="Project update with many labels"
                          Summary="This mail has more labels than the medium mode allows."
                          Labels="@_overflowLabels"
                          ReceivedAt="DateTime.Now.AddHours(-2)"
                          IsRead="true"
                          Href="#" />
            </div>
        </div>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Read vs Unread</Heading>
    <p class="text-muted mb-3">Unread mails have a primary-colored left border and a filled envelope icon.</p>
    <div class="d-flex flex-column gap-3" style="max-width: 30rem;">
        <MailCard Mode="MailCardMode.Medium"
                  SenderName="Alice"
                  SenderEmail="alice@example.com"
                  Subject="Unread message"
                  Summary="This message has not been read yet."
                  ReceivedAt="DateTime.Now.AddMinutes(-30)"
                  IsRead="false"
                  Href="#" />
        <MailCard Mode="MailCardMode.Medium"
                  SenderName="Bob"
                  SenderEmail="bob@example.com"
                  Subject="Read message"
                  Summary="This message has already been read."
                  ReceivedAt="DateTime.Now.AddHours(-3)"
                  IsRead="true"
                  Href="#" />
    </div>
</Card>

@code {
    private MailCardMode _mode = MailCardMode.Large;
    private string _senderName = "Alice Johnson";
    private string _senderEmail = "alice.johnson@example.com";
    private string _subject = "Q1 Report: Revenue exceeded expectations across all regions";
    private string _summary = "Hi team, I wanted to share the Q1 results. Revenue came in at 12% above forecast, driven primarily by strong performance in EMEA and APAC regions. The full breakdown is attached.";
    private DateTime _receivedAt = DateTime.Now.AddHours(-2);
    private bool _isRead;
    private string _href = "#";
    private ElementReference _codeElement;

    private List<MailCardLabel> _labels =
    [
        new("Important", "#b6004f"),
        new("Work", "#1D76DB"),
        new("Finance", "#0E8A16")
    ];

    private static readonly IReadOnlyList<MailCardLabel> _overflowLabels =
    [
        new("Important", "#b6004f"),
        new("Work", "#1D76DB"),
        new("Finance", "#0E8A16"),
        new("Urgent", "#d73a4a"),
        new("Q1", "#6f42c1")
    ];

    private void AddLabel() =>
        _labels.Add(new MailCardLabel("New Label", "#6f42c1"));

    private void RemoveLabel(int index) =>
        _labels.RemoveAt(index);

    private void UpdateLabel(int index, string name, string? color) =>
        _labels[index] = new MailCardLabel(name, color);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var labelStr = _labels.Count > 0
                ? $"\n              Labels=\"@_labels\""
                : "";
            var summaryStr = !string.IsNullOrWhiteSpace(_summary)
                ? $"\n              Summary=\"{_summary}\""
                : "";
            var readStr = _isRead ? "\n              IsRead=\"true\"" : "";

            return $"""
                <MailCard Mode="MailCardMode.{_mode}"
                          SenderName="{_senderName}"
                          SenderEmail="{_senderEmail}"
                          Subject="{_subject}"{summaryStr}{labelStr}
                          ReceivedAt="@_receivedAt"{readStr}
                          Href="{_href}" />
                """;
        }
    }
}

@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="ToggleButtonGroup" Icon="toggles" Subtitle="Mutually exclusive toggle buttons with radio group semantics" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>A row of mutually exclusive toggle buttons where exactly one is selected at a time. Uses <code>role="radiogroup"</code> and <code>role="radio"</code> for accessibility. Supports arrow key navigation.</p>
    <table class="table table-sm">
        <thead><tr><th>Parameter</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
        <tbody>
            <tr><td><code>Items</code></td><td><code>IReadOnlyList&lt;ToggleButtonItem&gt;</code></td><td>&#8212;</td><td>Available options</td></tr>
            <tr><td><code>SelectedId</code></td><td><code>string</code></td><td>&#8212;</td><td>Currently selected item ID</td></tr>
            <tr><td><code>SelectedIdChanged</code></td><td><code>EventCallback&lt;string&gt;</code></td><td>&#8212;</td><td>Fires when selection changes</td></tr>
            <tr><td><code>Class</code></td><td><code>string?</code></td><td><code>null</code></td><td>Extra CSS classes</td></tr>
        </tbody>
    </table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex align-items-center gap-2 mb-3">
        <label class="form-label mb-0">Items:</label>
        <CircularButton AriaLabel="Remove item" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                        Disabled="@(_itemCount <= 1)" OnClick="RemoveItem">
            <Icon Name="dash" Size="IconSize.Small" />
        </CircularButton>
        <span class="fw-semibold">@_itemCount</span>
        <CircularButton AriaLabel="Add item" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                        Disabled="@(_itemCount >= 20)" OnClick="AddItem">
            <Icon Name="plus" Size="IconSize.Small" />
        </CircularButton>
    </div>
    <div class="showcase-preview-area">
        <ToggleButtonGroup Items="VisibleItems" @bind-SelectedId="_selectedId" />
        <p class="text-muted mt-2 mb-0">Selected: <strong>@_selectedId</strong></p>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private int _itemCount = 3;
    private string _selectedId = "option-1";
    private ElementReference _codeElement;

    private IReadOnlyList<ToggleButtonItem> VisibleItems =>
        Enumerable.Range(1, _itemCount).Select(i => new ToggleButtonItem($"option-{i}", $"Option {i}")).ToList();

    private void AddItem()
    {
        if (_itemCount < 20) _itemCount++;
    }

    private void RemoveItem()
    {
        if (_itemCount <= 1) return;
        _itemCount--;
        if (!VisibleItems.Any(i => i.Id == _selectedId))
        {
            _selectedId = VisibleItems[^1].Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var items = string.Join(",\n        ", VisibleItems.Select(i => $"new(\"{i.Id}\", \"{i.Label}\")"));
            return "<ToggleButtonGroup Items=\"_items\"\n" +
                   "    @bind-SelectedId=\"_selectedId\" />\n" +
                   "\n" +
                   "@code {\n" +
                   $"    private string _selectedId = \"{_selectedId}\";\n" +
                   "\n" +
                   "    private static readonly IReadOnlyList<ToggleButtonItem> _items =\n" +
                   "    [\n" +
                   $"        {items}\n" +
                   "    ];\n" +
                   "}";
        }
    }
}

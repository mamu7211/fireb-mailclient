meta {
  name: Get Avatar After Upload
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/avatars/994171873e8ab734a7f67ba5895948c8
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should return PNG image", function() {
    expect(res.headers["content-type"]).to.equal("image/png");
  });
}

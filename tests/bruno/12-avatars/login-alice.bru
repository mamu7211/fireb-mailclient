meta {
  name: Login Alice
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{aliceUsername}}",
    "password": "{{alicePassword}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("aliceAccessToken", res.body.accessToken);
  }
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });
}

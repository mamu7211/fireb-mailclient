meta {
  name: Upload Avatar Invalid File
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/avatars/YWRtaW5AZmVpcmIubG9jYWw
  body: multipart-form
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  file: @file(invalid-file.txt)
}

tests {
  test("should return 400", function() {
    expect(res.status).to.equal(400);
  });

  test("should return error message", function() {
    expect(res.body.message).to.be.a("string");
  });
}

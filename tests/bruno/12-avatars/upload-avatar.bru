meta {
  name: Upload Avatar
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/api/avatars/994171873e8ab734a7f67ba5895948c8
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  file: @file(12-avatars/avatar-test.png)
}

tests {
  test("should return 204", function() {
    expect(res.status).to.equal(204);
  });
}
